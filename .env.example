# OpenAI API key — used only for embeddings (FAISS indexing and retrieval).
# Generation is handled by the self-hosted model server; this key is NOT
# used for LLM inference.
OPENAI_API_KEY=your_openai_api_key_here

VECTORSTORE_PATH=./vectorstore
DATA_PATH=./data
LOGS_PATH=./logs
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K=3
CONFIDENCE_THRESHOLD=0.7
MIN_CHUNK_QUALITY=0.35
RERANK_ALPHA=0.6
# Minimum top-chunk similarity for a factual question to skip the LLM
# and return the retrieved chunk directly.
FACTUAL_DIRECT_THRESHOLD=0.82
# Illustrative per-1K-token cost estimates (USD), used only by /stats.
LLM_INPUT_COST_PER_1K=0.0005
LLM_OUTPUT_COST_PER_1K=0.0015
# Optional: set to require callers to send a matching X-API-Key header
API_KEY=

# Self-hosted inference backend.
# LLM_BACKEND: "vllm" (default) or "llamacpp"
#   vllm     — vLLM server; default base URL http://llm-server:8000
#   llamacpp — llama.cpp server; default base URL http://llm-server:8080
LLM_BACKEND=vllm

# LLM_BASE_URL overrides the per-backend default above.
# Set this if your server runs on a non-default host or port.
# LLM_BASE_URL=http://localhost:8000

# Model name sent in the /v1/chat/completions request body.
# For vLLM: must match the --model argument the server was started with.
# For llama.cpp: any non-empty string (the server ignores it).
LLM_MODEL=mistral-7b-instruct
LLM_TEMPERATURE=0.1
# Seconds to wait for a model response before raising InferenceError.
LLM_TIMEOUT_SECS=120
